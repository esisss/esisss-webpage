---
// ContactSection.astro
import type { TranslateFn } from "../i18n/utils";

interface Props {
  t?: TranslateFn;
}

const { t } = Astro.props as Props;
---
<section id="contact" class="w-full h-screen flex flex-col items-center justify-center bg-transparent px-6 border-t border-zinc-900/80">
  <div class="max-w-3xl mx-auto text-center">
    <h2 class="text-4xl md:text-6xl font-extrabold text-white mb-6">{t?.("contact.title")}</h2>
    <p class="text-xl text-gray-400 mb-10 max-w-xl mx-auto">
      {t?.("contact.text")}
    </p>
    <a
      href="mailto:contact@example.com"
      class="inline-block px-8 py-4 bg-white text-black font-semibold text-lg rounded-full hover:bg-gray-200 hover:scale-105 transition-all duration-300 shadow-lg"
    >
      {t?.("contact.button")}
    </a>
  </div>
</section>
