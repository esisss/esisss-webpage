---
// SkillsSection.astro
---
<section id="skills" class="w-full h-[50vh] flex items-center justify-center bg-black px-6 border-y border-zinc-900">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl md:text-5xl font-bold text-white mb-6">Skills & Tools</h2>
    <div class="flex flex-wrap justify-center gap-4 text-gray-300">
      <span class="px-4 py-2 bg-zinc-800 rounded-full">Astro</span>
      <span class="px-4 py-2 bg-zinc-800 rounded-full">Three.js</span>
      <span class="px-4 py-2 bg-zinc-800 rounded-full">TypeScript</span>
      <span class="px-4 py-2 bg-zinc-800 rounded-full">TailwindCSS</span>
      <span class="px-4 py-2 bg-zinc-800 rounded-full">React</span>
      <span class="px-4 py-2 bg-zinc-800 rounded-full">Node.js</span>
    </div>
  </div>
</section>
